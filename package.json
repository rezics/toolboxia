{
  "name": "toolboxia",
  "version": "0.1.2",
  "description": "A citty-based script toolbox with interactive command picker",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "toolboxia": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "cli": "bun run src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "copy-assets": "bun run src/utils/copy-assets.ts",
    "build": "tsc -p tsconfig.build.json && bun run copy-assets",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@inquirer/search": "^4.1.6",
    "citty": "^0.2.1",
    "clipboardy": "^5.3.1",
    "env-paths": "^4.0.0",
    "yaml": "^2.8.2"
  }
}
