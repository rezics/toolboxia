{
  "name": "toolboxia",
  "version": "0.1.0",
  "description": "A citty-based script toolbox with interactive command picker",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "toolboxia": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "cli": "bun run src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@inquirer/search": "^4.1.6",
    "citty": "^0.2.1",
    "yaml": "^2.8.2"
  }
}
